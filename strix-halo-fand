#!/usr/bin/env python3
"""
strix-halo-fand: direct Embedded-Controller fan control for AMD Strix Halo
(Ryzen AI Max+ 395) mini-PCs whose firmware locks the fan curve and exposes
no standard Linux fan control (no hwmon PWM, no fan tach, no ACPI fan object).

Validated on the Bosgame M5 (ITE IT5570 EC). The EC register offsets below were
reverse-engineered from the board's ACPI DSDT. They may differ on other boards --
see README ("Adapting to your board") before running.

Fail-safe by design:
  * the curve only ever cools *harder* than stock -- it never sets a low duty at
    high temp;
  * on ANY error (unreadable temp, EC write failure) or on stop/SIGTERM it writes
    0x00 to hand the fan back to the firmware's own auto curve;
  * a minimum-duty floor keeps airflow up even if something wedges;
  * optional Prometheus export is fully isolated -- a telemetry error can never
    interrupt fan control.

You are still poking an Embedded Controller. Use at your own risk. The worst
realistic outcome is a fan stuck at 100% (loud, but safe) until reboot.
"""
import glob, time, os, signal, sys

# ---------------- CONFIG (verify for your board -- see README) ----------------
EC    = "/sys/kernel/debug/ec/ec0/io"   # kernel ec_sys write interface
FAN1  = 0x33            # fan1 duty register (write 0x80|duty; 0x00 = firmware auto)
FAN2  = 0x34            # fan2 duty register; set to None for a single-fan board
INTERVAL = 2.0         # seconds between updates
FLOOR = 30             # minimum duty %% -- never starve airflow
# Fan curve: (temp_below_degC, duty_percent), ascending. Tune to taste.
# This default is "max performance": ramps hard, 100%% by 82 C.
CURVE = [(50, 45), (60, 55), (70, 70), (78, 85), (82, 95), (999, 100)]
# Temp sources: hwmon driver names; the daemon drives off the HOTTEST of these.
TEMP_SOURCES = ["amdgpu", "k10temp"]

# ---- Optional Prometheus export (opt-in; leave PROM_FILE = None to disable) ----
# Point PROM_FILE at a file inside node_exporter's --collector.textfile.directory
# (e.g. "/var/lib/prometheus/node-exporter/strix-halo-fan.prom"). node_exporter
# then serves these on its OWN /metrics -- no extra port, no extra exporter:
#   strixhalo_fan_duty_percent{fan="1|2"}
#   strixhalo_fan_rpm{fan="1|2"}
#   strixhalo_temp_celsius{sensor="amdgpu|k10temp"}
PROM_FILE = None
# Fan tachometer registers per fan as (msb_offset, lsb_offset): rpm = (ec[msb]<<8)|ec[lsb].
# On the M5/IT5570 the firmware (DSDT) packs fan1 as (byte@0x35 << 8)|byte@0x36 -- note the
# byte at the LOWER offset is the HIGH byte. Verify the order on your board (see README).
TACH = [(0x35, 0x36), (0x37, 0x38)]
# -----------------------------------------------------------------------------


def find_hwmon(name):
    for p in glob.glob("/sys/class/hwmon/hwmon*"):
        try:
            if open(p + "/name").read().strip() == name:
                return p
        except OSError:
            pass
    return None


SENSORS = [(n, p) for n, p in ((n, find_hwmon(n)) for n in TEMP_SOURCES) if p]


def read_temp(path):
    try:
        return int(open(path + "/temp1_input").read()) / 1000.0
    except OSError:
        return None


def ec_write(offset, byte):
    with open(EC, "r+b") as f:
        f.seek(offset)
        f.write(bytes([byte]))


def ec_read():
    try:
        with open(EC, "rb") as f:
            return f.read()
    except OSError:
        return None


def set_duty(pct):
    pct = max(FLOOR, min(100, int(pct)))
    ec_write(FAN1, 0x80 | pct)               # bit7 = manual override
    if FAN2 is not None:
        ec_write(FAN2, 0x80 | pct)


def set_auto():
    try:
        ec_write(FAN1, 0x00)                  # hand back to firmware auto curve
        if FAN2 is not None:
            ec_write(FAN2, 0x00)
    except OSError:
        pass


def duty_for(temp):
    for ceiling, duty in CURVE:
        if temp < ceiling:
            return duty
    return 100


# The EC updates the two tach bytes non-atomically, so a single read can tear into
# garbage. Take two reads ~20ms apart and accept a fan's value only if both agree
# and are plausible; otherwise hold the last-known-good so the exported series stays
# continuous instead of dropping samples.
_last_rpm = {}


def read_tach():
    a = ec_read()
    time.sleep(0.02)
    b = ec_read()
    if a and b:
        for i, (msb, lsb) in enumerate(TACH):
            ra = (a[msb] << 8) | a[lsb]
            rb = (b[msb] << 8) | b[lsb]
            if 50 <= ra <= 12000 and 50 <= rb <= 12000 and abs(ra - rb) <= 400:
                _last_rpm[i] = (ra + rb) // 2
    return _last_rpm


def write_metrics(readings, duty):
    if not PROM_FILE:
        return
    try:                                      # telemetry must NEVER break fan control
        L = ["# TYPE strixhalo_fan_duty_percent gauge"]
        L.append('strixhalo_fan_duty_percent{fan="1"} %d' % duty)
        if FAN2 is not None:
            L.append('strixhalo_fan_duty_percent{fan="2"} %d' % duty)
        rpm = read_tach()
        L.append("# TYPE strixhalo_fan_rpm gauge")
        for i in sorted(rpm):
            L.append('strixhalo_fan_rpm{fan="%d"} %d' % (i + 1, rpm[i]))
        L.append("# TYPE strixhalo_temp_celsius gauge")
        for name, t in readings:
            L.append('strixhalo_temp_celsius{sensor="%s"} %.1f' % (name, t))
        tmp = PROM_FILE + ".tmp"
        with open(tmp, "w") as f:
            f.write("\n".join(L) + "\n")
        os.chmod(tmp, 0o644)
        os.replace(tmp, PROM_FILE)            # atomic swap: never expose a partial file
    except Exception:
        pass


def on_exit(*_):
    set_auto()
    sys.exit(0)


def main():
    if len(sys.argv) > 1 and sys.argv[1] == "--auto":
        set_auto()
        return
    if not SENSORS:
        print("no temp sensors found among %s; aborting" % TEMP_SOURCES, file=sys.stderr)
        sys.exit(1)
    signal.signal(signal.SIGTERM, on_exit)
    signal.signal(signal.SIGINT, on_exit)
    n = 0
    while True:
        try:
            readings = [(name, read_temp(p)) for name, p in SENSORS]
            readings = [(name, t) for name, t in readings if t is not None]
            if not readings:
                set_auto()                    # can't read temp -> firmware auto
            else:
                t = max(t for _, t in readings)
                d = duty_for(t)
                set_duty(d)
                write_metrics(readings, d)
                if n % 15 == 0:               # ~every 30s at 2s interval
                    print("temp=%.0fC -> fan=%d%%" % (t, d), flush=True)
        except Exception as e:                # never let a control error persist
            set_auto()
            print("error: %s -> firmware auto" % e, flush=True)
        n += 1
        time.sleep(INTERVAL)


if __name__ == "__main__":
    main()
